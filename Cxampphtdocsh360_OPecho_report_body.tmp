<?php require_once("ajax/footer.php"); ?>

<script>
$(document).ready(function() {
    <?php if ($SessionUserId != "1"): ?>
    fetchEchoPatients();
    <?php endif; ?>
    loadEchoHistory();
    $('#echo_patientName, #echo_mobile, #echo_patientId, #echo_appointId').select2();
});

// ---- Patient select2 population ----
$(document).on('change', '#echo_patientName, #echo_mobile, #echo_patientId, #echo_appointId', function() {
    echoPatientInfo($(this).attr('id'), $(this).val());
});

function fetchEchoPatients() {
    var orgId = $('#echo_org').val() || '<?= $SessionOrgId ?>';
    if (!orgId) return;
    $.ajax({
        url: 'ajax/Allpatientreports/fetchpatientdetails.php',
        method: 'GET',
        dataType: 'json',
        data: { org_id: orgId },
        success: function(data) {
            $('#echo_patientName').empty().append('<option value="">Select Patient Name</option>');
            $('#echo_mobile').empty().append('<option value="">Select Mobile</option>');
            $('#echo_patientId').empty().append('<option value="">Select Patient ID</option>');
            $('#echo_appointId').empty().append('<option value="">Select Appointment ID</option>');

            var mobileMap = {}, unicodeMap = {}, registerMap = {};
            (data.mobile_numbers    || []).forEach(function(i){ mobileMap[i.appoint_id]   = i.mobile_number; });
            (data.patient_ids       || []).forEach(function(i){ unicodeMap[i.appoint_id]  = i.appoint_unicode; });
            (data.appointment_ids   || []).forEach(function(i){ registerMap[i.appoint_id] = i.appoint_register_id; });

            (data.patient_names || []).forEach(function(item) {
                var id = item.appoint_id;
                $('#echo_patientName').append('<option value="'+id+'">'+item.patient_name+'</option>');
                if (mobileMap[id])   $('#echo_mobile').append('<option value="'+id+'">'+mobileMap[id]+'</option>');
                if (unicodeMap[id])  $('#echo_patientId').append('<option value="'+id+'">'+unicodeMap[id]+'</option>');
                if (registerMap[id]) $('#echo_appointId').append('<option value="'+id+'">'+registerMap[id]+'</option>');
            });
            ['#echo_patientName','#echo_mobile','#echo_patientId','#echo_appointId'].forEach(function(s){ $(s).trigger('change.select2'); });
        }
    });
}

function echoPatientInfo(fieldName, fieldValue) {
    var orgId = $('#echo_org').val() || '<?= $SessionOrgId ?>';
    $.ajax({
        url: 'ajax/Allpatientreports/patientinformation.php',
        type: 'POST',
        data: { organization_id: orgId, fieldName: fieldName, fieldValue: fieldValue },
        dataType: 'json',
        success: function(resp) {
            if (!resp.success) return;
            var d = resp.data;
            var updateSel = function(sel, val, id) {
                var $s = $(sel);
                if ($s.find("option[value='"+id+"']").length === 0)
                    $s.append(new Option(val, id, true, true)).trigger('change.select2');
                else
                    $s.val(id).trigger('change.select2');
            };
            updateSel('#echo_patientName', d.patientName,       d.appoint_id);
            updateSel('#echo_mobile',      d.mobileNumber,       d.appoint_id);
            updateSel('#echo_patientId',   d.appointUnicode,     d.appoint_id);
            updateSel('#echo_appointId',   d.appointRegisterId,  d.appoint_id);
        }
    });
}

// ---- Load patient data into form ----
function loadEchoForm() {
    var appoint_id = $('#echo_appointId').val();
    var orgId = $('#echo_org').val() || '<?= $SessionOrgId ?>';
    if (!appoint_id) {
        swal('', 'Please select a patient first.', 'warning');
        return;
    }
    $.ajax({
        url: 'ajax/Allpatientreports/patientinformation.php',
        type: 'POST',
        data: { organization_id: orgId, fieldName: 'appointRegisterId', fieldValue: appoint_id },
        dataType: 'json',
        success: function(resp) {
            if (!resp.success) return;
            var d = resp.data;
            // Fetch full appointment details for age/gender/doctor
            $.ajax({
                url: 'ajax/echoreport/getAppointmentDetails.php',
                type: 'POST',
                data: { appoint_id: appoint_id, org_id: orgId },
                dataType: 'json',
                success: function(r) {
                    resetEchoForm(false);
                    $('#echo_name').val(r.patient_name || d.patientName);
                    $('#echo_date').val(r.appoint_date || '<?= date('Y-m-d') ?>');
                    $('#echo_age').val(r.age || '');
                    $('#echo_gender').val(r.gender || '');
                    $('#echo_ref_by').val(r.doctor_name || '');
                    $('#echo_appointment_id').val(d.appointRegisterId);
                    $('#echo_patient_id_val').val(d.appointUnicode);
                    $('#echoFormCard').show();
                    $('#echoFormTitle').text('2D Echo Report — ' + (r.patient_name || d.patientName));
                }
            });
        }
    });
}

function newEchoReport() {
    resetEchoForm(false);
    $('#echoFormCard').show();
    $('#echoFormTitle').text('2D Echocardiographic Report — New');
}

function resetEchoForm(hide) {
    if (hide === undefined || hide === true) { $('#echoFormCard').hide(); }
    $('#echo_report_id').val('');
    $('#echo_appointment_id').val('');
    $('#echo_patient_id_val').val('');
    $('#echo_name').val('');
    $('#echo_date').val('<?= date('Y-m-d') ?>');
    $('#echo_age').val('');
    $('#echo_gender').val('');
    $('#echo_ref_by').val('');
    $('#echo_indication').val('');
    $('#echo_mitral').val('Normal');
    $('#echo_aortic').val('Normal');
    $('#echo_tricuspid').val('Normal');
    $('#echo_pulmonary_valve').val('Normal');
    $('#echo_left_atrium').val('');
    $('#echo_lvid_d').val('');
    $('#echo_lvid_s').val('');
    $('#echo_ef').val('');
    $('#echo_ivs_thickness').val('');
    $('#echo_pwd').val('');
    $('#echo_lv_rwma').val('NO RWMA');
    $('#echo_right_atrium').val('Normal');
    $('#echo_right_ventricle').val('Normal');
    $('#echo_tapse').val('');
    $('#echo_aorta').val('');
    $('#echo_ajv').val('');
    $('#echo_pulmonary_artery').val('Normal');
    $('#echo_pjv').val('');
    $('#echo_ivs_status').val('Intact');
    $('#echo_ias_status').val('Intact');
    $('#echo_ivc_svc_cs').val('Normal');
    $('#echo_pericardium').val('No PE');
    $('#echo_mitral_flow').val('');
    $('#echo_mr').val('NO');
    $('#echo_ar').val('NO');
    $('#echo_tr').val('NO');
    $('#echo_pr').val('NO');
    $('#echo_conclusion').val('');
    $('#echo_doctor_name').val('');
    $('#echo_doctor_cred').val('');
}

// ---- Save ----
$(document).on('click', '#saveEchoBtn', function() {
    var name = $('#echo_name').val().trim();
    if (!name) { swal('', 'Patient Name is required.', 'warning'); return; }

    var orgId = $('#echo_org').val() || '<?= $SessionOrgId ?>';
    $.ajax({
        url: 'ajax/echoreport/saveEchoReport.php',
        type: 'POST',
        data: {
            echo_report_id:       $('#echo_report_id').val(),
            org_id:               orgId,
            appointment_id:       $('#echo_appointment_id').val(),
            patient_id:           $('#echo_patient_id_val').val(),
            patient_name:         name,
            report_date:          $('#echo_date').val(),
            age:                  $('#echo_age').val(),
            gender:               $('#echo_gender').val(),
            ref_by:               $('#echo_ref_by').val(),
            indication:           $('#echo_indication').val(),
            mitral_valve:         $('#echo_mitral').val(),
            aortic_valve:         $('#echo_aortic').val(),
            tricuspid_valve:      $('#echo_tricuspid').val(),
            pulmonary_valve:      $('#echo_pulmonary_valve').val(),
            left_atrium:          $('#echo_left_atrium').val(),
            lvid_d:               $('#echo_lvid_d').val(),
            lvid_s:               $('#echo_lvid_s').val(),
            ef:                   $('#echo_ef').val(),
            ivs_thickness:        $('#echo_ivs_thickness').val(),
            pwd:                  $('#echo_pwd').val(),
            lv_rwma:              $('#echo_lv_rwma').val(),
            right_atrium:         $('#echo_right_atrium').val(),
            right_ventricle:      $('#echo_right_ventricle').val(),
            tapse:                $('#echo_tapse').val(),
            aorta:                $('#echo_aorta').val(),
            ajv:                  $('#echo_ajv').val(),
            pulmonary_artery:     $('#echo_pulmonary_artery').val(),
            pjv:                  $('#echo_pjv').val(),
            ivs_status:           $('#echo_ivs_status').val(),
            ias_status:           $('#echo_ias_status').val(),
            ivc_svc_cs:           $('#echo_ivc_svc_cs').val(),
            pericardium:          $('#echo_pericardium').val(),
            mitral_flow:          $('#echo_mitral_flow').val(),
            doppler_mr:           $('#echo_mr').val(),
            doppler_ar:           $('#echo_ar').val(),
            doppler_tr:           $('#echo_tr').val(),
            doppler_pr:           $('#echo_pr').val(),
            conclusion:           $('#echo_conclusion').val(),
            doctor_name:          $('#echo_doctor_name').val(),
            doctor_credentials:   $('#echo_doctor_cred').val()
        },
        dataType: 'json',
        success: function(resp) {
            if (resp.success) {
                swal('', resp.message, 'success').then(function() {
                    resetEchoForm(true);
                    loadEchoHistory();
                });
            } else {
                swal('Error', resp.message, 'error');
            }
        }
    });
});

// ---- History ----
function loadEchoHistory() {
    var orgId = $('#echo_org').val() || '<?= $SessionOrgId ?>';
    $.ajax({
        url: 'ajax/echoreport/getEchoReports.php',
        type: 'POST',
        data: { org_id: orgId },
        success: function(html) {
            $('#echoHistoryContainer').html(html);
            if ($.fn.DataTable.isDataTable('#echoReportHistoryTable'))
                $('#echoReportHistoryTable').DataTable().destroy();
            $('#echoReportHistoryTable').DataTable({ order: [[0,'desc']], pageLength: 10 });
        }
    });
}

// ---- Edit ----
$(document).on('click', '.edit-echo-btn', function() {
    var id = $(this).data('id');
    $.ajax({
        url: 'ajax/echoreport/getEchoReportById.php',
        type: 'POST',
        data: { echo_report_id: id },
        dataType: 'json',
        success: function(resp) {
            if (!resp.success) { swal('Error','Record not found','error'); return; }
            var d = resp.data;
            $('#echo_report_id').val(d.echo_report_id);
            $('#echo_appointment_id').val(d.appointment_id || '');
            $('#echo_patient_id_val').val(d.patient_id || '');
            $('#echo_name').val(d.patient_name);
            $('#echo_date').val(d.report_date);
            $('#echo_age').val(d.age);
            $('#echo_gender').val(d.gender);
            $('#echo_ref_by').val(d.ref_by);
            $('#echo_indication').val(d.indication);
            $('#echo_mitral').val(d.mitral_valve);
            $('#echo_aortic').val(d.aortic_valve);
            $('#echo_tricuspid').val(d.tricuspid_valve);
            $('#echo_pulmonary_valve').val(d.pulmonary_valve);
            $('#echo_left_atrium').val(d.left_atrium);
            $('#echo_lvid_d').val(d.lvid_d);
            $('#echo_lvid_s').val(d.lvid_s);
            $('#echo_ef').val(d.ef);
            $('#echo_ivs_thickness').val(d.ivs_thickness);
            $('#echo_pwd').val(d.pwd);
            $('#echo_lv_rwma').val(d.lv_rwma);
            $('#echo_right_atrium').val(d.right_atrium);
            $('#echo_right_ventricle').val(d.right_ventricle);
            $('#echo_tapse').val(d.tapse);
            $('#echo_aorta').val(d.aorta);
            $('#echo_ajv').val(d.ajv);
            $('#echo_pulmonary_artery').val(d.pulmonary_artery);
            $('#echo_pjv').val(d.pjv);
            $('#echo_ivs_status').val(d.ivs_status);
            $('#echo_ias_status').val(d.ias_status);
            $('#echo_ivc_svc_cs').val(d.ivc_svc_cs);
            $('#echo_pericardium').val(d.pericardium);
            $('#echo_mitral_flow').val(d.mitral_flow);
            $('#echo_mr').val(d.doppler_mr);
            $('#echo_ar').val(d.doppler_ar);
            $('#echo_tr').val(d.doppler_tr);
            $('#echo_pr').val(d.doppler_pr);
            $('#echo_conclusion').val(d.conclusion);
            $('#echo_doctor_name').val(d.doctor_name);
            $('#echo_doctor_cred').val(d.doctor_credentials);
            $('#echoFormCard').show();
            $('#echoFormTitle').text('Edit Echo Report — ' + d.patient_name);
            $('html, body').animate({ scrollTop: $('#echoFormCard').offset().top - 20 }, 400);
        }
    });
});

// ---- Delete ----
$(document).on('click', '.delete-echo-btn', function() {
    var id = $(this).data('id');
    swal({ title: 'Delete this report?', text: 'This cannot be undone.', icon: 'warning',
           buttons: ['Cancel', 'Delete'], dangerMode: true })
    .then(function(confirm) {
        if (!confirm) return;
        $.ajax({
            url: 'ajax/echoreport/deleteEchoReport.php',
            type: 'POST',
            data: { echo_report_id: id },
            dataType: 'json',
            success: function(resp) {
                if (resp.success) { swal('', resp.message, 'success').then(loadEchoHistory); }
                else { swal('Error', resp.message, 'error'); }
            }
        });
    });
});

// ---- View (print) ----
var _echoViewUrl = <?= json_encode(
    (isset($_SERVER['HTTPS']) && $_SERVER['HTTPS']==='on' ? 'https' : 'http')
    . '://' . $_SERVER['HTTP_HOST']
    . rtrim(dirname($_SERVER['SCRIPT_NAME']), '/')
    . '/ajax/echoreport/viewEchoReport.php'
) ?>;

function viewEchoReport(id) {
    if (!id) { swal('', 'Invalid report ID.', 'error'); return; }
    var f = document.createElement('form');
    f.method = 'POST'; f.action = _echoViewUrl; f.target = '_blank';
    var inp = document.createElement('input');
    inp.type = 'hidden'; inp.name = 'echo_report_id'; inp.value = id;
    f.appendChild(inp);
    document.body.appendChild(f);
    f.submit();
    document.body.removeChild(f);
}

<?php if ($SessionUserId == "1"): ?>
$(document).on('change', '#echo_org', function() {
    fetchEchoPatients();
    loadEchoHistory();
});
<?php endif; ?>
</script>
